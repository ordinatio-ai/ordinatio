{
  "name": "@ordinatio/email",
  "version": "1.0.3",
  "private": false,
  "license": "MIT",
  "description": "Multi-provider email engine with OAEM protocol",
  "engines": {
    "node": ">=22.0.0"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./schemas": "./src/schemas.ts",
    "./errors": "./src/errors.ts",
    "./oaem": "./src/oaem/index.ts"
  },
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "import": "./dist/index.js",
        "types": "./dist/index.d.ts"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --clean",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "cbor-x": "^1.6.0",
    "imapflow": "^1.2.12",
    "jose": "^6.0.0",
    "mailparser": "^3.9.3",
    "nodemailer": "^8.0.1"
  },
  "devDependencies": {
    "@ordinatio/core": "^1.0.0",
    "@types/mailparser": "^3.4.6",
    "@types/nodemailer": "^7.0.11",
    "typescript": "5",
    "vitest": "4.0.18",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "@prisma/client": "^7.3.0",
    "googleapis": ">=140.0.0",
    "zod": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "@prisma/client": {
      "optional": true
    },
    "googleapis": {
      "optional": true
    }
  }
}